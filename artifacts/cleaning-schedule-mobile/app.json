{
  "expo": {
    "name": "Tidy Home",
    "slug": "cleaning-schedule-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cleaning-schedule-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F8F6"
    },
    "ios": {
      "bundleIdentifier": "com.dandosiggins.tidyhome",
      "supportsTablet": false
    },
    "android": {
      "package": "com.dandosiggins.tidyhome"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "22d2e05d-6949-48d5-bc68-e9f343a4df0a"
      }
    }
  }
}
